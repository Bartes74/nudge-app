%% Nudge — ER Diagram (Mermaid)
%% Wersja: 0.2 (MVP v1 + guided beginner path) — 2026-04-18
%% Podgląd: https://mermaid.live lub w VS Code z rozszerzeniem Mermaid
%% Uwaga: pokazujemy najważniejsze relacje; pełny schemat — plik .dbml

erDiagram

    users ||--|| user_profile : "1:1"
    users ||--o{ user_profile_facts : "source of truth"
    users ||--o{ body_measurements : "history"
    users ||--|| user_equipment : "1:1"
    users ||--|| user_training_preferences : "1:1"
    users ||--|| user_nutrition_preferences : "1:1"
    users ||--|| user_health : "1:1"
    users ||--o{ user_safety_flags : "active flags"
    users ||--o{ user_goals : "current + history"
    users ||--o{ user_segment_snapshots : "computed"
    users ||--o{ subscriptions : "billing"
    users ||--|| behavior_signals : "rolling counters"
    users ||--o{ training_plans : "logical plans"
    users ||--o{ nutrition_plans : "logical plans"
    users ||--o{ workout_logs : "what user did"
    users ||--o{ meal_logs : "meal entries"
    users ||--o{ checkin_sessions : "weekly"
    users ||--o{ user_question_asks : "adaptive questions"
    users ||--o{ coach_conversations : "chat threads"
    users ||--o{ ai_tasks : "AI jobs"
    users ||--o{ ai_decisions : "audit"
    users ||--o{ llm_calls : "cost tracking"
    users ||--o{ safety_escalations : "critical events"
    users ||--o{ notifications : "push/email/in-app"
    users ||--o{ product_events : "analytics mirror"

    training_plans ||--o{ training_plan_versions : "versioned"
    training_plan_versions ||--o{ plan_workouts : "week structure"
    plan_workouts ||--o{ plan_exercises : "exercise list"
    plan_workouts ||--o{ plan_workout_steps : "guided flow"
    plan_exercises }o--|| exercises : "from catalog"
    plan_workout_steps }o--o| exercises : "optional catalog ref"

    workout_logs ||--o{ workout_log_exercises : "per exercise"
    workout_log_exercises ||--o{ workout_log_sets : "per set"
    workout_log_exercises }o--|| exercises : "catalog ref"
    workout_logs }o--o| plan_workouts : "if not ad-hoc"

    nutrition_plans ||--o{ nutrition_plan_versions : "versioned"

    meal_logs ||--o{ meal_log_items : "ingredients"
    meal_logs ||--o{ meal_images : "photos"
    meal_logs }o--o| llm_calls : "vision call"

    nutrition_daily_totals }o--|| users : "per day cache"

    question_library ||--o{ user_question_asks : "instances"

    coach_conversations ||--o{ coach_messages : "messages"
    coach_messages }o--o| llm_calls : "if assistant"

    ai_tasks }o--o| llm_calls : "may spawn"
    training_plan_versions }o--o| ai_tasks : "generated by"
    nutrition_plan_versions }o--o| ai_tasks : "generated by"

    prompts ||--o{ llm_calls : "prompt used"

    field_explanations }o--|| question_library : "by field_key"

    user_ai_usage }o--|| users : "monthly aggregate"

    users {
        uuid id PK
        text email
        timestamptz created_at
        timestamptz last_active_at
        text timezone
        text locale
    }

    user_profile {
        uuid user_id PK
        enum gender
        enum age_bucket
        enum experience_level
        enum primary_goal
        text_array life_context
        enum tone_preset
        enum nutrition_mode
    }

    user_profile_facts {
        uuid id PK
        uuid user_id FK
        text field_key
        jsonb value_json
        enum source
        numeric confidence
        timestamptz observed_at
    }

    training_plan_versions {
        uuid id PK
        uuid plan_id FK
        int version_number
        text change_reason
        jsonb goal_snapshot
        jsonb week_structure
        uuid llm_call_id FK
    }

    meal_logs {
        uuid id PK
        uuid user_id FK
        timestamptz logged_at
        enum meal_type
        enum input_mode
        int kcal_min
        int kcal_max
        numeric confidence
        bool user_corrected
    }

    llm_calls {
        uuid id PK
        uuid user_id FK
        text provider
        text model
        int tokens_in
        int tokens_out
        numeric cost_usd
        int latency_ms
    }

    user_safety_flags {
        uuid id PK
        uuid user_id FK
        enum flag
        enum status
        enum severity
        jsonb restrictions_applied
    }

    question_library {
        uuid id PK
        text field_key
        enum layer
        text_array applicable_segments
        int priority_base
        text why_we_ask
        text how_to_measure
    }
