// ============================================================
// Nudge App — Database Schema (DBML)
// Wersja: 0.3 (odzwierciedla stan migracji po iter10: beginner_zero, monetyzacja, meal logger)
// Data: 2026-04-18
// Podgląd: https://dbdiagram.io (wklej cały plik)
// ============================================================
//
// Zasada: MIGRACJE SĄ ŹRÓDŁEM PRAWDY. Ten plik odtwarza stan
// zbudowany przez kolejne pliki w `supabase/migrations/`. Jeśli
// znajdziesz rozbieżność — najpierw sprawdź w migracji, potem
// popraw DBML. Nowe pola dodajemy migracją, nie edycją DBML.
//
// Konwencje:
// - Wszystkie id: uuid (Supabase generuje domyślnie)
// - Wszystkie timestamps: timestamptz
// - Soft delete: kolumna `deleted_at` tam, gdzie trzeba
// - RLS: każda tabela user-scoped ma polityki RLS (poza katalogami)
// - JSONB: używamy dla danych polimorficznych / opcjonalnych,
//   ale płaskie pola preferujemy, bo są indeksowalne
// ============================================================


// ---------- GRUPA 1: AUTH & SUBSKRYPCJA ----------

Table users {
  id uuid [pk, note: 'Supabase auth.users.id']
  email text [unique, not null]
  created_at timestamptz [default: `now()`]
  last_active_at timestamptz
  deleted_at timestamptz
  timezone text [default: 'Europe/Warsaw']
  locale text [default: 'pl-PL']
  note: 'Mirror/extension Supabase auth. Nie trzymamy hasła.'
}

Table subscriptions {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  status subscription_status [not null, default: 'trial']
  plan subscription_plan [note: 'NULL do momentu checkoutu']
  provider text [note: 'stripe | revenuecat']
  provider_subscription_id text
  provider_customer_id text
  trial_started_at timestamptz
  trial_ends_at timestamptz
  current_period_start timestamptz
  current_period_end timestamptz
  paused_until timestamptz
  cancelled_at timestamptz
  price_amount integer [note: 'Grosze/cents (np. 4900 = 49,00 PLN)']
  price_currency text [not null, default: 'PLN']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    user_id [unique]
    status
  }
}

Enum subscription_status {
  trial
  active
  paused
  past_due
  cancelled
  expired
}

Enum subscription_plan {
  monthly
  yearly
}


// ---------- GRUPA 2: PROFIL UŻYTKOWNIKA ----------

// Tabela z "twardymi" polami denormalizowanymi dla szybkiego dostępu.
// Źródłem prawdy jest user_profile_facts (poniżej).
// user_profile aktualizuje się po każdej zmianie facts (trigger/job).
Table user_profile {
  user_id uuid [pk, ref: > users.id]
  display_name text
  birth_date date
  age_bucket age_bucket  [note: 'Derywowany z birth_date']
  gender gender
  height_cm numeric(5,2)
  current_weight_kg numeric(5,2)
  experience_level experience_level
  primary_goal primary_goal
  dietary_constraints text[]
  life_context text[]
  onboarding_completed_at timestamptz
  onboarding_layer_1_done boolean [default: false]
  onboarding_layer_2_done boolean [default: false]
  last_plan_generated_at timestamptz
  tone_preset tone_preset [note: 'Z segmentu; można overridować']
  nutrition_mode nutrition_mode [note: 'simple | ranges | exact']
  entry_path entry_path
  adaptation_phase adaptation_phase
  needs_guided_mode boolean [not null, default: false]
  inferred_beginner_status boolean [not null, default: false]
  inferred_beginner_reason_codes text[] [not null, default: `'{}'`]
  trainer_consultation_recommended_at timestamptz
  trainer_consultation_completed_at timestamptz
  trainer_feedback_notes text
  updated_at timestamptz
}

Enum gender {
  female
  male
  other
  prefer_not_to_say
}

Enum age_bucket {
  under_25
  age_25_40
  age_40_55
  age_55_plus
}

Enum experience_level {
  beginner_zero
  beginner
  intermediate
  advanced
}

Enum primary_goal {
  weight_loss
  muscle_building
  strength_performance
  general_health
}

Enum tone_preset {
  warm_encouraging
  partnering
  factual_technical
  calm_guided
}

Enum entry_path {
  guided_beginner
  standard_training
}

Enum adaptation_phase {
  phase_0_familiarization
  phase_1_adaptation
  phase_2_foundations
}

Enum nutrition_mode {
  simple
  ranges
  exact
}

// Event-sourced: każdy fakt o userze zapisany osobno,
// z confidence, source, timestamp. Nigdy nie nadpisujemy — dopisujemy.
Table user_profile_facts {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  field_key text [not null, note: 'np. "weight_kg", "home_gym_access", "preferred_split"']
  value_text text
  value_numeric numeric
  value_bool boolean
  value_json jsonb [note: 'dla złożonych wartości: tablice, enum listy']
  unit text [note: 'np. "kg", "cm", "days_per_week"']
  source fact_source [not null]
  confidence numeric(3,2) [note: '0.00 — 1.00']
  inferred_from text [note: 'id encji, z której zinferowano fakt']
  supersedes_id uuid [ref: > user_profile_facts.id]
  observed_at timestamptz [not null, default: `now()`]
  note: 'Source of truth. user_profile to zdenormalizowany cache. APPEND-ONLY (brak UPDATE/DELETE policy).'

  indexes {
    (user_id, field_key, observed_at)
  }
}

Enum fact_source {
  onboarding
  user_input
  user_correction
  ai_inferred
  behavioral_signal
  measurement_device
  photo_analysis
  checkin
  coach_chat
}


// ---------- GRUPA 3: POMIARY CIAŁA ----------

Table body_measurements {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  measured_at timestamptz [not null]
  weight_kg numeric(5,2)
  waist_cm numeric(5,2)
  hips_cm numeric(5,2)
  chest_cm numeric(5,2)
  thigh_cm numeric(5,2)
  arm_cm numeric(5,2)
  neck_cm numeric(5,2)
  body_fat_pct numeric(4,2) [note: 'Zgadywane lub z urządzenia']
  notes text
  source fact_source [not null, default: 'user_input']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, measured_at)
  }
}


// ---------- GRUPA 4: SPRZĘT, PREFERENCJE, ZDROWIE ----------

Table user_equipment {
  user_id uuid [pk, ref: > users.id]
  location_type location_type [note: 'home | gym | mixed']
  has_barbell boolean [default: false]
  has_dumbbells boolean [default: false]
  has_kettlebells boolean [default: false]
  has_machines boolean [default: false]
  has_cables boolean [default: false]
  has_cardio boolean [default: false]
  has_pullup_bar boolean [default: false]
  has_bench boolean [default: false]
  dumbbell_max_kg numeric(5,2)
  other_equipment text[]
  updated_at timestamptz
}

Enum location_type {
  home
  gym
  mixed
}

Table user_training_preferences {
  user_id uuid [pk, ref: > users.id]
  days_per_week integer
  session_duration_min integer
  liked_exercises text[] [not null, default: `'{}'`]
  disliked_exercises text[] [not null, default: `'{}'`]
  avoid_exercises text[] [not null, default: `'{}'`, note: 'Hard block — np. z powodu bólu']
  preferred_location location_type
  prefers_guided_mode boolean [not null, default: false]
  updated_at timestamptz [not null, default: `now()`]
}

Table user_nutrition_preferences {
  user_id uuid [pk, ref: > users.id]
  nutrition_mode nutrition_mode
  prioritize_regular_meals boolean [not null, default: true]
  prioritize_protein boolean [not null, default: true]
  prioritize_hydration boolean [not null, default: true]
  preferred_meal_count integer
  avoid_foods text[] [not null, default: `'{}'`]
  updated_at timestamptz [not null, default: `now()`]
}

// Minimalny zestaw w migracji; pola rozszerzone (past_injuries, sleep_*,
// stress_level, energy_level, work_type, steps_per_day) zostaną dodane
// w przyszłych iteracjach — sygnalizowane przez question_library.
Table user_health {
  user_id uuid [pk, ref: > users.id]
  injuries text[]
  chronic_pain text[]
  medical_conditions text[]
  activity_level activity_level
  notes text
  updated_at timestamptz
}

Enum activity_level {
  sedentary
  light
  moderate
  active
  very_active
}

// Flagi guardrails (z ADR-002). Mogą być user-deklarowane lub automatyczne.
Table user_safety_flags {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  flag safety_flag [not null]
  status flag_status [not null, default: 'active']
  source text [note: 'onboarding, detection_rule, coach_chat, user_report']
  severity severity_level [not null]
  detected_at timestamptz [default: `now()`]
  resolved_at timestamptz
  notes text
  restrictions_applied jsonb [note: 'co blokujemy w planie/rekomendacjach']

  indexes {
    (user_id, flag, status)
  }
}

Enum safety_flag {
  underage
  pregnancy
  postpartum
  ed_risk
  low_calorie_intake
  rapid_weight_loss
  injury_reported
  acute_pain
  medical_condition
  medication_interaction
  overtraining_signs
}

Enum flag_status {
  active
  monitoring
  resolved
  dismissed_by_user
}

Enum severity_level {
  info
  warning
  critical
}


// ---------- GRUPA 5: CELE I SEGMENTY ----------

// Cel ewoluuje w czasie — trzymamy historię.
Table user_goals {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  goal_type primary_goal [not null]
  target_value numeric [note: 'np. docelowa masa, siła, obwód']
  target_unit text
  secondary_goal text
  horizon_weeks integer
  rationale text [note: 'dlaczego ten cel — user own words']
  started_at timestamptz [default: `now()`]
  ended_at timestamptz
  is_current boolean [default: true]

  indexes {
    (user_id, is_current)
  }
}

// Computed snapshot segmentu — do szybkich raportów i routingu promptów.
Table user_segment_snapshots {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  experience_level experience_level
  primary_goal primary_goal
  gender gender
  age_bucket age_bucket
  life_context text[]
  segment_key text [note: 'np. "beginner_zero_weight_loss"']
  entry_path entry_path
  adaptation_phase adaptation_phase
  computed_at timestamptz [default: `now()`]

  indexes {
    (user_id, computed_at)
  }
}


// ---------- GRUPA 6: KATALOG ĆWICZEŃ (GLOBAL) ----------

Table exercises {
  id uuid [pk]
  slug text [unique, not null]
  name_pl text [not null]
  name_en text
  plain_language_name text
  simple_goal_description text
  category exercise_category
  primary_muscles text[] [not null, default: `'{}'`]
  secondary_muscles text[] [not null, default: `'{}'`]
  equipment_required text[] [not null, default: `'{}'`]
  difficulty difficulty
  is_compound boolean [not null, default: false]
  technique_notes text
  common_mistakes text
  setup_instructions text
  execution_steps text[] [not null, default: `'{}'`]
  tempo_hint text
  breathing_hint text
  safety_notes text
  easy_substitution_slugs text[] [not null, default: `'{}'`]
  machine_busy_substitution_slugs text[] [not null, default: `'{}'`]
  stop_conditions text[] [not null, default: `'{}'`]
  starting_load_guidance text
  video_url text
  alternatives_slugs text[] [not null, default: `'{}'`, note: 'Domyślne zamienniki']
  tags text[] [not null, default: `'{}'`]
  created_at timestamptz [not null, default: `now()`]
  deprecated boolean [not null, default: false]
}

Enum exercise_category {
  push
  pull
  legs
  core
  cardio
  mobility
  full_body
}

Enum difficulty {
  beginner
  intermediate
  advanced
}


// ---------- GRUPA 7: PLAN TRENINGOWY (Z WERSJONOWANIEM) ----------

// Jeden "plan" = logiczny kontener. Konkretna zawartość to version.
Table training_plans {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  name text
  current_version_id uuid [ref: > training_plan_versions.id, note: 'FK DEFERRABLE INITIALLY DEFERRED']
  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz
  is_active boolean [not null, default: true]

  indexes {
    (user_id, is_active)
  }
}

Table training_plan_versions {
  id uuid [pk]
  plan_id uuid [ref: > training_plans.id, not null]
  version_number integer [not null]
  created_at timestamptz [not null, default: `now()`]
  created_by_ai_task_id uuid [ref: > ai_tasks.id]
  change_reason text [note: 'np. "user zgłosił ból barku", "plateau 3 tygodnie"']
  goal_snapshot jsonb [note: 'cel aktualny przy generacji']
  assumptions_snapshot jsonb
  progression_rules jsonb
  week_structure jsonb [note: 'np. {"mon":"upper","wed":"lower","fri":"full"}']
  additional_notes text
  llm_call_id uuid [ref: > llm_calls.id]
  guided_mode boolean [not null, default: false]
  adaptation_phase adaptation_phase
  view_mode plan_view_mode [not null, default: 'standard_training_view']

  indexes {
    (plan_id, version_number) [unique]
  }
}

// Pojedynczy "trening" w wersji planu (np. "Upper A")
Table plan_workouts {
  id uuid [pk]
  plan_version_id uuid [ref: > training_plan_versions.id, not null]
  day_label text [note: 'np. "mon", "upper_a"']
  order_in_week integer [not null, default: 1]
  name text
  duration_min_estimated integer
  confidence_goal text
  warmup_notes text
  cooldown_notes text
}

Enum plan_view_mode {
  guided_beginner_view
  standard_training_view
}

// Ćwiczenia w konkretnym treningu — rozpiska.
Table plan_exercises {
  id uuid [pk]
  plan_workout_id uuid [ref: > plan_workouts.id, not null]
  exercise_id uuid [ref: > exercises.id]
  order_num integer [not null, default: 1]
  sets integer
  reps_min integer
  reps_max integer
  rir_target numeric(3,1)
  rpe_target numeric(3,1)
  rest_seconds integer
  tempo text [note: 'np. "3-0-1-0"']
  technique_notes text
  substitute_exercise_ids uuid[] [not null, default: `'{}'`]
}

Enum guided_step_type {
  arrival_prep
  warmup
  main_block
  cooldown
  post_workout_summary
}

Table plan_workout_steps {
  id uuid [pk]
  plan_workout_id uuid [ref: > plan_workouts.id, not null]
  step_type guided_step_type [not null]
  order_num integer [not null, default: 1]
  title text [not null]
  duration_min integer
  exercise_id uuid [ref: > exercises.id]
  instruction_text text [not null]
  setup_instructions text
  execution_steps text[] [not null, default: `'{}'`]
  tempo_hint text
  breathing_hint text
  safety_notes text
  common_mistakes text
  stop_conditions text[] [not null, default: `'{}'`]
  machine_settings text
  substitution_policy jsonb
  starting_load_guidance text
  is_new_skill boolean [not null, default: false]
}

Enum substitution_reason {
  machine_busy
  unclear
  discomfort
  too_hard
}


// ---------- GRUPA 8: LOG TRENINGU ----------

Table workout_logs {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  plan_workout_id uuid [ref: > plan_workouts.id, note: 'NULL jeśli ad-hoc trening']
  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz
  duration_min integer
  pre_mood pre_mood
  pre_energy energy_level
  overall_rating integer [note: 'CHECK 1-5 po treningu']
  clarity_score integer [note: 'CHECK 1-5 — jasność instrukcji']
  confidence_score integer [note: 'CHECK 1-5 — pewność wykonania']
  felt_safe boolean
  exercise_confusion_flag boolean [not null, default: false]
  machine_confusion_flag boolean [not null, default: false]
  too_hard_flag boolean [not null, default: false]
  pain_flag boolean [not null, default: false]
  ready_for_next_workout boolean
  tempo_feedback text
  went_well text
  went_poorly text
  what_to_improve text
  notes text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, started_at)
  }
}

Enum pre_mood {
  bad
  ok
  good
  great
}

Enum energy_level {
  low
  moderate
  high
  variable
}

Table workout_log_exercises {
  id uuid [pk]
  workout_log_id uuid [ref: > workout_logs.id, not null]
  exercise_id uuid [ref: > exercises.id]
  plan_exercise_id uuid [ref: > plan_exercises.id]
  order_num integer [not null, default: 1]
  notes text
  was_substituted boolean [not null, default: false]
  original_exercise_id uuid [ref: > exercises.id]
}

Table workout_log_sets {
  id uuid [pk]
  workout_log_exercise_id uuid [ref: > workout_log_exercises.id, not null]
  set_number integer [not null]
  weight_kg numeric(5,2)
  reps integer
  rir numeric(3,1)
  to_failure boolean [not null, default: false]
  duration_sec integer [note: 'dla planku, cardio itp.']
  created_at timestamptz [not null, default: `now()`]
}


// ---------- GRUPA 9: PLAN ŻYWIENIOWY ----------

Table nutrition_plans {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  current_version_id uuid [ref: > nutrition_plan_versions.id, note: 'FK DEFERRABLE INITIALLY DEFERRED']
  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz
  is_active boolean [not null, default: true]
}

Table nutrition_plan_versions {
  id uuid [pk]
  plan_id uuid [ref: > nutrition_plans.id, not null]
  version_number integer [not null]
  created_at timestamptz [not null, default: `now()`]
  created_by_ai_task_id uuid [ref: > ai_tasks.id]
  change_reason text
  mode nutrition_mode [not null, default: 'simple']
  calories_target integer
  protein_g_target integer
  fat_g_target integer
  carbs_g_target integer
  fiber_g_target integer
  water_ml_target integer
  meal_distribution jsonb [note: 'np. [{"meal":1,"kcal_share":0.25,"time":"08:00"}]']
  strategy_notes text
  practical_guidelines jsonb [note: 'listy: bazowe produkty, źródła białka, do ograniczenia']
  supplement_recommendations jsonb [note: '{sensible:[], optional:[], unnecessary:[]}']
  emergency_plan jsonb [note: 'co robić przy: brak czasu, impreza, głód, spadek energii, stagnacja']
  llm_call_id uuid [ref: > llm_calls.id]

  indexes {
    (plan_id, version_number) [unique]
  }
}


// ---------- GRUPA 10: LOG ŻYWIENIA (ZDJĘCIA + WPISY) ----------

// UWAGA: migracja nie ma `logged_at timestamptz`, tylko `date` — posiłek jest
// agregowany per dzień, a nie konkretna godzina. Timestamp jest w `created_at`.
Table meal_logs {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  logged_at date [not null, default: `CURRENT_DATE`]
  meal_type meal_type
  source meal_source [not null]
  status meal_log_status [not null, default: 'pending_analysis']
  note text [note: 'User-provided context for the photo (opcjonalne)']

  // Range estimates populated by vision analyzer; NULL for manual entries
  kcal_estimate_min integer
  kcal_estimate_max integer
  protein_g_min numeric(6,1)
  protein_g_max numeric(6,1)
  carbs_g_min numeric(6,1)
  carbs_g_max numeric(6,1)
  fat_g_min numeric(6,1)
  fat_g_max numeric(6,1)

  confidence_score numeric(3,2) [note: 'CHECK BETWEEN 0 AND 1']
  user_warnings jsonb [note: 'array<string> ostrzeżeń z analyzera']

  llm_call_id uuid [ref: > llm_calls.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, logged_at)
    status [note: 'partial: WHERE status = pending_analysis']
  }
}

Enum meal_type {
  breakfast
  lunch
  dinner
  snack
  drink
  dessert
}

Enum meal_source {
  photo
  manual
}

Enum meal_log_status {
  pending_analysis
  analyzed
  failed
  manual
}

Table meal_log_items {
  id uuid [pk]
  meal_log_id uuid [ref: > meal_logs.id, not null]
  user_id uuid [ref: > users.id, not null, note: 'Denormalizacja dla prostszego RLS — match z meal_logs.user_id']
  label text [not null]
  portion_estimate text
  grams_estimate numeric(7,1)
  kcal_estimate integer
  protein_g numeric(6,1)
  carbs_g numeric(6,1)
  fat_g numeric(6,1)
  is_user_corrected boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    meal_log_id
    user_id
  }
}

Table meal_images {
  id uuid [pk]
  meal_log_id uuid [ref: > meal_logs.id, not null]
  user_id uuid [ref: > users.id, not null]
  storage_path text [not null, note: 'Supabase Storage bucket meal_photos, prefix = auth.uid()']
  uploaded_at timestamptz [not null, default: `now()`]

  indexes {
    meal_log_id
  }
}

// Dzienne podliczenia. Aktualizowane triggerem po INSERT/UPDATE/DELETE
// na meal_logs i meal_log_items (funkcja recalculate_nutrition_daily_totals).
Table nutrition_daily_totals {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  date date [not null]
  kcal_total integer [not null, default: 0]
  protein_g_total numeric(7,1) [not null, default: 0]
  carbs_g_total numeric(7,1) [not null, default: 0]
  fat_g_total numeric(7,1) [not null, default: 0]
  meal_count integer [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, date) [unique]
  }
}


// ---------- GRUPA 11: CHECK-INY TYGODNIOWE ----------

Table checkin_sessions {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  week_of date [not null, note: 'Poniedziałek tygodnia']

  // Auto-agregaty z workout_logs (liczone przy GET /checkin/current)
  workouts_completed integer
  workouts_planned integer
  avg_workout_rating numeric(3,1)

  // Auto-agregaty z body_measurements
  weight_measurements integer
  weight_start_kg numeric(5,2)
  weight_end_kg numeric(5,2)
  weight_delta_kg numeric(5,2)

  // Subjective sliders 1-5 (CHECK BETWEEN 1 AND 5)
  subjective_energy integer
  subjective_recovery integer
  subjective_motivation integer
  subjective_stress integer
  subjective_sleep integer

  // Free text — 3 pola
  wins_text text
  struggles_text text
  focus_next_week text

  // LLM verdict
  verdict checkin_verdict
  verdict_summary text
  recommended_action text
  plan_change_needed boolean [not null, default: false]
  plan_change_details jsonb

  // Meta
  submitted_at timestamptz
  analysis_at timestamptz
  llm_call_id uuid [ref: > llm_calls.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, week_of) [unique]
  }
}

Enum checkin_verdict {
  on_track
  needs_adjustment
  plan_change_recommended
}


// ---------- GRUPA 12: SYGNAŁY BEHAWIORALNE (z ADR-003) ----------

// "Silnik monitoringu" w wersji prostej: liczniki.
// Writes tylko przez service role (brak RLS INSERT/UPDATE policy).
Table behavior_signals {
  user_id uuid [pk, ref: > users.id]
  days_since_last_workout_log integer
  workout_completion_rate_7d numeric(3,2)
  workout_completion_rate_30d numeric(3,2)
  clarity_score_avg_7d numeric(3,2)
  clarity_score_avg_14d numeric(3,2)
  clarity_score_avg_30d numeric(3,2)
  confidence_score_avg_7d numeric(3,2)
  confidence_score_avg_14d numeric(3,2)
  confidence_score_avg_30d numeric(3,2)
  meal_logs_per_day_7d numeric(4,2)
  photo_vs_text_ratio numeric(3,2)
  onboarding_fields_skipped integer [not null, default: 0]
  weight_log_regularity_score numeric(3,2)
  avg_session_length_sec integer
  last_question_answered_at timestamptz
  coach_messages_sent_7d integer [not null, default: 0]
  exercise_confusion_count_7d integer [not null, default: 0]
  exercise_confusion_count_14d integer [not null, default: 0]
  exercise_confusion_count_30d integer [not null, default: 0]
  machine_confusion_count_7d integer [not null, default: 0]
  substitution_count_7d integer [not null, default: 0]
  substitution_count_14d integer [not null, default: 0]
  substitution_count_30d integer [not null, default: 0]
  aborted_exercise_count_7d integer [not null, default: 0]
  pain_flag_count_7d integer [not null, default: 0]
  pain_flag_count_14d integer [not null, default: 0]
  pain_flag_count_30d integer [not null, default: 0]
  too_hard_flag_count_7d integer [not null, default: 0]
  last_proactive_coach_at timestamptz
  missed_workouts_7d integer [not null, default: 0]
  days_since_registration integer [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]
}


// ---------- GRUPA 13: PYTANIA ADAPTACYJNE ----------

// Katalog pytań (definicje) — per pole profilu lub temat.
Table question_library {
  id uuid [pk]
  field_key text [not null, note: 'Mapuje na user_profile_facts.field_key']
  layer question_layer [not null]
  applicable_segments text[]
  applicable_goals primary_goal[]
  priority_base integer [note: 'Bazowy priorytet 1-100']
  why_we_ask text [not null, note: 'Krótkie "po co"']
  how_to_measure text [note: 'Krótka podpowiedź']
  phrasing_options jsonb [note: 'Różne warianty brzmienia per ton']
  answer_type answer_type [not null]
  answer_options jsonb [note: 'Dla single/multi select']
  blocks_if_unanswered boolean [default: false]
  expected_time_seconds integer
  prerequisites jsonb [note: 'Warunki: jakie inne pola muszą być wypełnione']
  is_active boolean [default: true]
}

Enum question_layer {
  layer_1_minimum
  layer_2_segment
  layer_3_behavioral
  layer_4_advanced
}

Enum answer_type {
  text_short
  text_long
  numeric
  single_select
  multi_select
  boolean
  scale
  measurement
  photo
}

// Instancje pytań zadanych konkretnemu userowi.
Table user_question_asks {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  question_id uuid [ref: > question_library.id, not null]
  asked_at timestamptz [default: `now()`]
  answered_at timestamptz
  skipped_at timestamptz
  answer_text text
  answer_numeric numeric
  answer_json jsonb
  context text [note: 'onboarding | checkin | coach_chat | proactive (legacy string)']
  source question_source [note: 'Ustrukturyzowany ekwiwalent context — dodany w iter9']
  checkin_session_id uuid [ref: > checkin_sessions.id]
  priority_score numeric(5,2) [note: 'Wyliczony w momencie zadania']

  indexes {
    (user_id, asked_at)
    checkin_session_id [note: 'partial: WHERE checkin_session_id IS NOT NULL']
  }
}

Enum question_source {
  contextual
  proactive
  checkin
  onboarding
}


// ---------- GRUPA 14: COACH — ROZMOWY ----------

Table coach_conversations {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  entry_point entry_point [not null, default: 'global_bubble', note: 'Z jakiego miejsca w apce']
  context_entity_type text [note: 'CHECK IN (exercise | meal | plan | checkin)']
  context_entity_id uuid
  started_at timestamptz [not null, default: `now()`]
  last_message_at timestamptz
  closed boolean [not null, default: false]

  indexes {
    (user_id, started_at)
  }
}

Enum entry_point {
  global_bubble
  exercise_shortcut
  meal_shortcut
  checkin_shortcut
  proactive_coach
  onboarding
}

Table coach_messages {
  id uuid [pk]
  conversation_id uuid [ref: > coach_conversations.id, not null]
  role message_role [not null]
  content text [not null]
  intent coach_intent [note: 'Klasyfikacja intencji wiadomości usera']
  tokens_in integer
  tokens_out integer
  llm_call_id uuid [ref: > llm_calls.id]
  guardrail_flagged boolean [not null, default: false]
  guardrail_reasons text[]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (conversation_id, created_at)
  }
}

Enum message_role {
  user
  assistant
  system
  tool
}

Enum coach_intent {
  technical_exercise
  diet
  motivation
  pain
  goal_extreme
  greeting
  other
}


// ---------- GRUPA 15: AI TASKS, DECYZJE, KOSZTY ----------

Table ai_tasks {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  task_type ai_task_type [not null]
  status ai_task_status [not null, default: 'queued']
  input_payload jsonb
  output_payload jsonb
  error text
  queued_at timestamptz [not null, default: `now()`]
  started_at timestamptz
  completed_at timestamptz

  indexes {
    (user_id, task_type, queued_at)
    status
  }
}

Enum ai_task_type {
  generate_training_plan
  generate_nutrition_plan
  analyze_meal_photo
  weekly_checkin_analysis
  pick_next_question
  classify_intent
  proactive_nudge
  recalculate_targets
}

Enum ai_task_status {
  queued
  running
  completed
  failed
  cancelled
}

// Decyzje podjęte przez warstwę reguł/coacha — pełen audyt (iter10 beginner_zero).
Table ai_decisions {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  ai_task_id uuid [ref: > ai_tasks.id]
  llm_call_id uuid [ref: > llm_calls.id]
  recommendation_type recommendation_type [not null]
  entry_path entry_path
  adaptation_phase adaptation_phase
  input_snapshot jsonb [note: 'Stan sygnałów i profilu w momencie decyzji']
  decision_payload jsonb [note: 'Konkretna rekomendacja (np. slow_down, repeat_session)']
  rationale text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, created_at)
  }
}

Enum recommendation_type {
  slow_down
  repeat_similar_session
  show_more_guidance
  trainer_consultation
  simplify_plan
  introduce_new_machine
  introduce_strength_basics
}

Table llm_calls {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  ai_task_id uuid [ref: > ai_tasks.id]
  provider text [not null, note: 'openai | anthropic | google']
  model text [not null, note: 'gpt-4o-mini | gpt-4o | ...']
  prompt_id uuid [ref: > prompts.id]
  prompt_version integer
  tokens_in integer
  tokens_out integer
  cost_usd numeric(10,6)
  latency_ms integer
  used_structured_output boolean [not null, default: false]
  output_valid boolean [not null, default: true]
  retries integer [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, created_at)
    (provider, model, created_at)
  }
}

Table prompts {
  id uuid [pk]
  slug text [not null, note: 'np. meal_vision_analysis, training_plan_fill, coach_*']
  version integer [not null]
  purpose text
  system_template text
  user_template text
  output_schema jsonb
  tone_preset tone_preset
  created_at timestamptz [not null, default: `now()`]
  deprecated boolean [not null, default: false]

  indexes {
    (slug, version) [unique]
  }
}

// Ostrzeżenia/zablokowane progresje z warstwy safety (iter10).
Table safety_escalations {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  source text [note: 'coach_chat | rule_engine | user_report']
  symptom_codes text[] [not null, default: `'{}'`]
  severity severity_level [not null, default: 'warning']
  status text [not null, default: 'open', note: 'open | acknowledged | resolved']
  blocked_progression boolean [not null, default: true]
  recommended_action text
  notes text
  created_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz

  indexes {
    (user_id, created_at)
  }
}

// Rate limiting i budżety per user.
Table user_ai_usage {
  user_id uuid [ref: > users.id, note: 'Część kompozytowego PK (user_id, month_key)']
  month_key text [note: 'YYYY-MM, np. "2026-04"']
  llm_calls_count integer [not null, default: 0]
  photo_analysis_count integer [not null, default: 0]
  tokens_in_total integer [not null, default: 0]
  tokens_out_total integer [not null, default: 0]
  cost_usd_total numeric(10,4) [not null, default: 0]
  over_limit boolean [not null, default: false]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, month_key) [pk]
    month_key
  }
}


// ---------- GRUPA 16: PROMPTOWANIE KONTEKSTOWE ("PO CO / JAK") ----------

// Teksty "po co pytamy" i "jak to zmierzyć" dla każdego pola.
// Osobna tabela, bo to copy można iterować bez zmiany schematu.
Table field_explanations {
  id uuid [pk]
  field_key text [not null]
  locale text [not null, default: 'pl-PL']
  why_we_ask text [not null]
  how_to_measure text
  example text
  estimated_time_seconds integer
  show_in_contexts text[] [note: 'onboarding | profile_fill | checkin | ...']
  updated_at timestamptz

  indexes {
    (field_key, locale) [unique]
  }
}


// ---------- GRUPA 17: POWIADOMIENIA I PROAKTYWNE NUDŻE ----------

Table notifications {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  type notification_type [not null]
  title text
  body text
  cta_deep_link text
  scheduled_for timestamptz
  sent_at timestamptz
  read_at timestamptz
  dismissed_at timestamptz
  data jsonb
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, scheduled_for) [note: 'partial: WHERE sent_at IS NULL']
    scheduled_for [note: 'partial: WHERE sent_at IS NULL — dla workera']
  }
}

Enum notification_type {
  workout_reminder
  meal_reminder
  checkin_due
  plan_ready
  coach_proactive_nudge
  milestone
  trial_reminder
  re_engagement
  subscription_renewal
}


// ---------- GRUPA 18: EVENTY PRODUKTOWE (do PostHog sync) ----------

// Lokalny mirror eventów + źródło do analiz produktowych,
// niezależny od zewnętrznych narzędzi.
Table product_events {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  event_name text [not null]
  properties jsonb
  session_id text
  occurred_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, occurred_at)
    (event_name, occurred_at)
  }
}


// ============================================================
// RELACJE KEY/FK (podsumowanie kluczowych — reszta inline wyżej)
// ============================================================
// users 1—1 user_profile
// users 1—* user_profile_facts
// users 1—* body_measurements
// users 1—* user_goals
// users 1—* training_plans (1 active na raz)
// training_plans 1—* training_plan_versions
// training_plan_versions 1—* plan_workouts 1—* plan_exercises
// plan_workouts 1—* plan_workout_steps (guided_beginner mode)
// users 1—* workout_logs (mogą być ad-hoc, bez plan_workout_id)
// users 1—* meal_logs 1—* meal_log_items, 1—* meal_images
// users 1—* checkin_sessions (unique per week_of)
// users 1—* user_safety_flags, safety_escalations
// users 1—* ai_tasks / ai_decisions / llm_calls
// users 1—1 behavior_signals (rolling counters)
// users 1—1 subscriptions (unique index na user_id)
// users 1—* coach_conversations 1—* coach_messages
// ============================================================
