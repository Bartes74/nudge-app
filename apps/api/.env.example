# Server
PORT=3001
NODE_ENV=development

# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry — https://sentry.io/<org>/<project>/settings/keys/
SENTRY_DSN=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PORTAL_CONFIG_ID=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@nudge.app

# Slack webhook for cost alerts — optional
SLACK_COST_ALERT_WEBHOOK_URL=

# Inngest — production keys from https://app.inngest.com/env/production/manage/keys
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=
