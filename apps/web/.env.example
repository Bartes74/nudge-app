# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL — used in OAuth redirects and email links
# Local: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry — https://sentry.io/<org>/<project>/settings/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — https://app.posthog.com/settings/project-api-keys
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Supabase Service Role — https://supabase.com/dashboard/project/<id>/settings/api
# WARNING: never expose this key in the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Inngest — job queue. Locally: "local" (no account needed).
# Production: get key from https://app.inngest.com/env/production/manage/keys
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# Dev tools — set to 'true' to enable /dev/* sandbox pages (never enable in production)
NEXT_PUBLIC_DEV_MODE=false

# OAuth — configure providers in Supabase Dashboard > Authentication > Providers
# Google: https://supabase.com/docs/guides/auth/social-login/auth-google
# Apple:  https://supabase.com/docs/guides/auth/social-login/auth-apple
# No env vars needed here — OAuth credentials live in Supabase Dashboard only.
# Set the redirect URL in each provider to: ${NEXT_PUBLIC_APP_URL}/auth/v1/callback
