# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
# On localhost, always point these three values to your local Supabase instance.
# Using a remote project here will make local debugging hit production-like data and storage.
# Required on Vercel: yes
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL — used in OAuth redirects and email links
# Local: http://localhost:3000 or http://localhost:3021  |  Production: https://your-domain.com
# Required on Vercel for auth links/admin testing: yes
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public API URL for billing/checkout calls from the web app
# Local: http://localhost:3001  |  Production: https://api.your-domain.com
# Required on Vercel: only for billing/checkout
NEXT_PUBLIC_API_URL=

# Sentry — https://sentry.io/<org>/<project>/settings/keys/
# Required on Vercel: optional
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — https://app.posthog.com/settings/project-api-keys
# Required on Vercel: yes
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Supabase Service Role — https://supabase.com/dashboard/project/<id>/settings/api
# WARNING: never expose this key in the browser. Server-side only.
# Required on Vercel for admin dashboard, creating users and server-side jobs: yes
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Required on Vercel for AI generation and analysis: yes
OPENAI_API_KEY=

# Inngest — job queue. Locally: "local" (no account needed).
# Production: get key from https://app.inngest.com/env/production/manage/keys
# Required on Vercel for async jobs: recommended
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# Stripe — optional for early staging/test builds, required for checkout/billing
# Required on Vercel: only for billing/checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=

# Dev tools — set to 'true' to enable /dev/* sandbox pages (never enable in production)
NEXT_PUBLIC_DEV_MODE=false

# OAuth — configure providers in Supabase Dashboard > Authentication > Providers
# Google: https://supabase.com/docs/guides/auth/social-login/auth-google
# Apple:  https://supabase.com/docs/guides/auth/social-login/auth-apple
# No env vars needed here — OAuth credentials live in Supabase Dashboard only.
# Set the redirect URL in each provider to: ${NEXT_PUBLIC_APP_URL}/auth/v1/callback
